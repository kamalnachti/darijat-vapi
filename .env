DARIJAT_API_KEY=curl -X POST https://tts.darijat.com/api/v1/external/generate-audio \
-H "Authorization: Bearer YOUR_API_TOKEN" \
-H "Content-Type: application/json" \
-d '{
    "text": "أهلاً بك في نظام الرد الآلي الذكي.",
    "voice_name": "مريم",
    "human_simulation": true,
    "style_instruction": "تتحدث بنبرة ودودة ومرحبة كخدمة عملاء"
}'